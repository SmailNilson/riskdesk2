# Local Codex -> proxy authentication
CODEX_BEDROCK_PROXY_TOKEN=replace-with-a-random-local-token

# AWS Bedrock Claude configuration
AWS_REGION=us-east-1
ANTHROPIC_BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-6-v1

# Optional if you want to use a non-default AWS CLI profile
# AWS_PROFILE=your-profile

# Optional proxy tuning
# CODEX_BEDROCK_PROXY_PORT=4141
# CODEX_BEDROCK_MAX_TOKENS=8192
# ANTHROPIC_BEDROCK_SONNET_MODEL_ID=global.anthropic.claude-sonnet-4-6
