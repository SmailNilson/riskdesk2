# Named local runtime profile for pointing the local RiskDesk SaaS to the
# IBKR Gateway running on the GCP production VM in LIVE mode.

PROFILE_NAME=local-ibkr-gcp

GCP_IAP_INSTANCE=riskdesk-prod-a
GCP_IAP_ZONE=us-central1-a

RISKDESK_IBKR_NATIVE_HOST=127.0.0.1
RISKDESK_IBKR_NATIVE_PORT=4003
RISKDESK_IBKR_NATIVE_CLIENT_ID=17
RISKDESK_LOCAL_BACKEND_PORT=8081

NEXT_PUBLIC_API_URL=http://localhost:8081
NEXT_PUBLIC_WS_URL=http://localhost:8081/ws
FRONTEND_PORT=3000
